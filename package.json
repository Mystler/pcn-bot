{
  "name": "prismatic-carrier-network",
  "type": "module",
  "version": "1.1.0",
  "description": "Discord Bot to announce Fleet Carrier updates via EDDN data",
  "main": "dist/bot.js",
  "scripts": {
    "start": "node --enable-source-maps .",
    "register": "node --enable-source-maps dist/register.js",
    "build": "tsc",
    "clean": "rm -r dist",
    "lint": "prettier --check src && eslint src",
    "format": "prettier --write src"
  },
  "author": "Mystler",
  "dependencies": {
    "discord.js": "^14.26.2",
    "handlebars": "^4.7.9",
    "zeromq": "^6.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "zeromq"
    ],
    "overrides": {
      "undici@<6.23.0": ">=6.23.0",
      "undici@>=6.0.0 <6.24.0": ">=6.24.0",
      "undici@<6.24.0": ">=6.24.0"
    }
  }
}
